{
  "name": "nickyt-site",
  "type": "module",
  "version": "1.0.0",
  "description": "Nick Taylor's personal website built with Astro",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "portless run astro dev",
    "start": "astro dev",
    "build": "npm run format:check && astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "format": "vp fmt . && vp lint --fix .",
    "format:check": "vp fmt --check . && vp lint --max-warnings 0 .",
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "prepare": "vp config"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/netlify": "^7.0.5",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@libsql/client": "^0.17.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@varlock/astro-integration": "^0.2.5",
    "astro": "^6.1.1",
    "astro-expressive-code": "^0.41.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lite-youtube-embed": "^0.3.4",
    "lucide-react": "^0.577.0",
    "luxon": "^3.7.2",
    "marked": "^17.0.1",
    "portless": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.6.0",
    "unist-util-visit": "^5.1.0",
    "varlock": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "dotenv": "^17.3.1",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.3.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "pagefind": "^1.4.0",
    "slugify": "^1.6.8",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.57.2",
    "vite-plus": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickytonline/nickytdotco"
  },
  "keywords": [
    "astro",
    "blog",
    "personal-website"
  ],
  "author": "Nick Taylor",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nickytonline/nickytdotco/issues"
  },
  "homepage": "https://www.nickyt.co",
  "packageManager": "npm@11.12.1",
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
