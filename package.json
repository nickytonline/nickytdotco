{
  "name": "nickyt-site",
  "type": "module",
  "version": "1.0.0",
  "description": "Nick Taylor's personal website built with Astro",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run format:check && astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && eslint --max-warnings 0 .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/netlify": "^7.0.5",
    "@astrojs/react": "^5.0.0",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@libsql/client": "^0.17.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@varlock/astro-integration": "^0.1.0",
    "astro": "^5.17.1",
    "astro-expressive-code": "^0.41.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lite-youtube-embed": "^0.3.4",
    "lucide-react": "^0.577.0",
    "luxon": "^3.7.2",
    "marked": "^17.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.6.0",
    "unist-util-visit": "^5.1.0",
    "varlock": "^0.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "slugify": "^1.6.8",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.57.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickytonline/nickytdotco"
  },
  "keywords": [
    "astro",
    "blog",
    "personal-website"
  ],
  "author": "Nick Taylor",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nickytonline/nickytdotco/issues"
  },
  "homepage": "https://www.nickyt.co",
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,mdx,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
