---
import StreamSchedule from "../components/StreamSchedule.astro";
import PastGuestCard from "../components/PastGuestCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import Layout from "../layouts/MainLayout.astro";
import type { StreamGuestInfo } from "../utils/schedule-utils";
import { getLiveCollection } from "astro:content";
import { getCollection } from "astro:content";
import { site } from "../data/site";
import { dateFilter } from "../utils/filters";
import { fetchPastGuestsWithYouTube } from "../content/_loaders/stream-schedule";
import TalkCard from "../components/TalkCard.astro";
import GuideCard from "../components/GuideCard.astro";

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

// Sort by date descending
const sortedPosts = allPosts.sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

const recentPosts = sortedPosts.slice(0, site.maxPostsPerPage);

const allTalks = await getCollection("talks");
const sortedTalks = allTalks.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const recentTalks = sortedTalks.slice(0, site.maxPostsPerPage);

const allGuides = await getCollection("guides");
const sortedGuides = allGuides.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const recentGuides = sortedGuides.slice(0, site.maxPostsPerPage);

const locale =
  Astro.request.headers.get("Accept-Language")?.split(",")[0] ||
  Astro.request.headers.get("Accept-Language") ||
  "en-US";

let errorMessage = "";
let schedule: StreamGuestInfo[] = [];
let pastGuests: StreamGuestInfo[] = [];

const scheduleResult = await getLiveCollection("streamSchedule");

if (scheduleResult.error) {
  console.error("Error fetching stream schedule:", scheduleResult.error);
  errorMessage = "Error fetching stream schedule.";
} else {
  schedule = scheduleResult.entries?.map((entry) => entry.data) ?? [];

  // Only fetch past guests if there are no upcoming streams
  if (schedule.length === 0) {
    pastGuests = await fetchPastGuestsWithYouTube();
  }
}

const { timezone = "" } = Astro.locals.netlify.context.geo;

if (!errorMessage) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=0, must-revalidate",
  );
  Astro.response.headers.set(
    "Netlify-CDN-Cache-Control",
    "public, max-age=259200, must-revalidate",
  );
  Astro.response.headers.set("timezone", timezone);
  Astro.response.headers.set("Netlify-Vary", "header=Accept-Language|timezone");
}

export const prerender = false;
---

<Layout
  title="Nick Taylor — Developer. Advocate. Builder."
  metaDesc="Developer Advocate at Pomerium specializing in Zero Trust security, MCP (Model Context Protocol), and agentic AI. Microsoft MVP, GitHub Star, and open source contributor."
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Nick Taylor",
        alternateName: "@nickytonline",
        jobTitle: "Developer Advocate at Pomerium",
        url: "https://www.nickyt.co",
        sameAs: [
          "https://github.com/nickytonline",
          "https://linkedin.com/in/nickytonline",
          "https://dev.to/nickytonline",
          "https://bsky.app/profile/nickyt.online",
          "https://x.com/nickytonline",
          "https://youtube.com/@nickytonline",
          "https://twitch.tv/nickytonline",
        ],
        knowsAbout: [
          "Zero Trust Security",
          "Model Context Protocol (MCP)",
          "Agentic AI",
          "TypeScript",
          "Developer Advocacy",
          "OpenClaw",
        ],
        worksFor: {
          "@type": "Organization",
          name: "Pomerium",
          url: "https://pomerium.com",
        },
      })}
    />
  </Fragment>
  <div class="space-y-12">
    <section class="flex flex-col md:flex-row gap-8 items-start">
      <img
        class="w-32 h-32 md:w-48 md:h-48 rounded-xl object-cover shrink-0"
        src="/assets/images/colour-headshot-500x500.jpg"
        alt="Headshot of Nick Taylor"
        loading="eager"
      />
      <div class="flex-1 space-y-4">
        <h1 class="text-3xl md:text-4xl font-bold">
          Developer. Advocate. Builder.
        </h1>
        <p class="text-lg leading-relaxed text-muted-foreground">
          <strong class="text-foreground"><em>Hi!</em> I'm Nick Taylor</strong> (<a href="/socials">@nickytonline</a>)
          — a developer advocate and software engineer at
          <a
            href="https://pomerium.com"
            >Pomerium</a
          >, Microsoft MVP, GitHub Star, and AWS Community Builder. I write,
          stream, and speak about Zero Trust security, agentic AI, MCP (Model
          Context Protocol), and open source.
        </p>
        <div class="rounded-xl border border-border bg-secondary/50 p-5">
          <p class="text-lg leading-relaxed text-muted-foreground">
            I run <a
              href="https://onetipaweek.com"
              class="text-pink-600 dark:text-pink-400 font-semibold hover:underline focus:underline focus:outline-none"
              >One Tip a Week</a
            > — a short newsletter with practical dev tips you can actually use.
            <a
              href="https://onetipaweek.com"
              class="inline-flex items-center gap-1 ml-1 text-pink-600 dark:text-pink-400 font-semibold hover:underline focus:underline focus:outline-none"
            >
              Subscribe <span class="text-xl">→</span>
            </a>
          </p>
        </div>
      </div>
    </section>

    <section class="space-y-12">
      <SectionHeader title="Latest Content" headingLevel={2} />

      <div class="space-y-10">
        <div>
          <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
            Talks
          </h3>
          <div class="grid gap-6 xl:gap-8">
            {
              recentTalks.map((talk) => (
                <TalkCard
                  title={talk.data.title}
                  venueName={talk.data.venue.name}
                  venueUrl={talk.data.venue.url}
                  date={dateFilter(talk.data.date)}
                  href={`/talks/${talk.id}`}
                  video={talk.data.video}
                />
              ))
            }
            <a
              href="/talks"
              class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-pink-600"
            >
              More talks<span class="text-2xl">→</span>
            </a>
          </div>
        </div>

        <div>
          <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
            Hands-On Tutorials
          </h3>
          <div class="grid gap-6 xl:gap-8">
            {
              recentGuides.map((guide) => (
                <GuideCard
                  title={guide.data.title}
                  description={guide.data.description}
                  date={dateFilter(guide.data.date)}
                  coverImage={guide.data.cover_image}
                  href={guide.data.url}
                  source={guide.data.source}
                />
              ))
            }
            <a
              href="https://labs.iximiuz.com/a/nickytonline"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-pink-600"
            >
              More guides on iximiuz Labs<span class="text-2xl">→</span>
            </a>
          </div>
        </div>

        {
          errorMessage ? (
            <div>
              <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
                Live Streams
              </h3>
              <p class="text-red-600">{errorMessage}</p>
            </div>
          ) : null
        }
        {
          !errorMessage && schedule.length > 0 ? (
            <div>
              <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
                Upcoming Live Streams
              </h3>
              <StreamSchedule
                schedule={schedule}
                locale={locale}
                timezone={timezone}
              />
              <a
                href="/videos"
                class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-pink-600"
              >
                More live streams<span class="text-2xl">→</span>
              </a>
            </div>
          ) : null
        }
        {
          !errorMessage && schedule.length === 0 && pastGuests.length > 0 ? (
            <div>
              <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
                Live Streams
              </h3>
              <div class="grid gap-6 xl:gap-8">
                {pastGuests.map((guest) => (
                  <PastGuestCard
                    guest={guest}
                    locale={locale}
                    timezone={timezone}
                  />
                ))}
              </div>
              <a
                href="/videos"
                class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-pink-600"
              >
                More live streams<span class="text-2xl">→</span>
              </a>
            </div>
          ) : null
        }

        <div>
          <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
            Blog Posts
          </h3>
          <div class="grid gap-6 xl:gap-8">
            {
              recentPosts.map((post) => (
                <BlogPostCard
                  title={post.data.title}
                  date={dateFilter(post.data.date)}
                  image={post.data.cover_image}
                  href={`/blog/${post.id}`}
                />
              ))
            }
            <a
              href="/blog"
              class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-pink-600">
              More blog posts<span class="text-2xl">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
