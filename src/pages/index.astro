---
import StreamSchedule from "../components/StreamSchedule.astro";
import PastGuestCard from "../components/PastGuestCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import Layout from "../layouts/MainLayout.astro";
import type { StreamGuestInfo } from "../utils/schedule-utils";
import { getLiveCollection } from "astro:content";
import { getCollection } from "astro:content";
import { dateFilter } from "../utils/filters";
import { fetchPastGuestsWithYouTube } from "../content/_loaders/stream-schedule";
import TalkCard from "../components/TalkCard.astro";
import GuideCard from "../components/GuideCard.astro";

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedPosts = allPosts.sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

// Featured: evergreen, curated best work (excluded from Latest to avoid duplication)
const featuredPosts = sortedPosts
  .filter((p) => p.data.featured === true)
  .slice(0, 2);
const featuredPostIds = new Set(featuredPosts.map((p) => p.id));

// Latest: recency feed, excludes featured posts
const recentPosts = sortedPosts
  .filter((p) => !featuredPostIds.has(p.id))
  .slice(0, 2);

const allTalks = await getCollection("talks");
const now = new Date();

// Featured talks: flagship, evergreen (must have a recording, not upcoming)
const featuredTalks = allTalks
  .filter((t) => t.data.featured === true && !t.data.upcoming)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
const featuredTalkIds = new Set(featuredTalks.map((t) => t.id));

// Latest talks: upcoming first (timely), then recent past (excluding featured)
const upcomingTalks = allTalks
  .filter(
    (t) => t.data.upcoming === true && (t.data.endDate ?? t.data.date) >= now,
  )
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .slice(0, 2);
const pastTalks = allTalks
  .filter((t) => !t.data.upcoming && !featuredTalkIds.has(t.id))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3 - upcomingTalks.length);
const recentTalks = [...upcomingTalks, ...pastTalks];

const allGuides = await getCollection("guides");
const sortedGuides = allGuides.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featuredGuides = sortedGuides
  .filter((g) => g.data.featured === true)
  .slice(0, 2);

const locale =
  Astro.request.headers.get("Accept-Language")?.split(",")[0] ||
  Astro.request.headers.get("Accept-Language") ||
  "en-US";

let errorMessage = "";
let schedule: StreamGuestInfo[] = [];
let pastGuests: StreamGuestInfo[] = [];
let latestUpcomingStreams: StreamGuestInfo[] = [];
let latestPastStreams: StreamGuestInfo[] = [];

const scheduleResult = await getLiveCollection("streamSchedule");

if (scheduleResult.error) {
  console.error("Error fetching stream schedule:", scheduleResult.error);
  errorMessage = "Error fetching stream schedule.";
} else {
  schedule = scheduleResult.entries?.map((entry) => entry.data) ?? [];
  latestUpcomingStreams = schedule
    .filter((stream) => new Date(stream.date).getTime() > now.getTime())
    .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
    .slice(0, 2);

  if (latestUpcomingStreams.length < 2) {
    pastGuests = await fetchPastGuestsWithYouTube();
    latestPastStreams = pastGuests.slice(0, 2 - latestUpcomingStreams.length);
  }
}

const { timezone = "" } = Astro.locals.netlify.context.geo;

if (!errorMessage) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=0, must-revalidate",
  );
  Astro.response.headers.set(
    "Netlify-CDN-Cache-Control",
    "public, max-age=259200, must-revalidate",
  );
  Astro.response.headers.set("timezone", timezone);
  Astro.response.headers.set("Netlify-Vary", "header=Accept-Language|timezone");
}

export const prerender = false;
---

<Layout
  title="Nick Taylor — Developer. Advocate. Builder."
  metaDesc="Developer Advocate at Pomerium specializing in Zero Trust security, MCP (Model Context Protocol), and agentic AI. GitHub Star, AAIF Ambassador, AWS Community Builder, and Microsoft MVP."
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Nick Taylor",
        alternateName: "@nickytonline",
        jobTitle: "Developer Advocate at Pomerium",
        url: "https://www.nickyt.co",
        sameAs: [
          "https://github.com/nickytonline",
          "https://linkedin.com/in/nickytonline",
          "https://dev.to/nickytonline",
          "https://bsky.app/profile/nickyt.online",
          "https://x.com/nickytonline",
          "https://youtube.com/@nickytonline",
          "https://twitch.tv/nickytonline",
        ],
        knowsAbout: [
          "Zero Trust Security",
          "Model Context Protocol (MCP)",
          "Agentic AI",
          "TypeScript",
          "Developer Advocacy",
          "OpenClaw",
        ],
        worksFor: {
          "@type": "Organization",
          name: "Pomerium",
          url: "https://pomerium.com",
        },
      })}
    />
  </Fragment>
  <div class="space-y-12">
    <section class="flex flex-col md:block overflow-hidden lg:mb-36">
      <img
        class="w-32 h-32 md:w-48 md:h-48 rounded-xl object-cover self-center mb-4 md:mb-0 md:float-left md:mr-8"
        src="/assets/images/colour-headshot-500x500.jpg"
        alt="Headshot of Nick Taylor"
        loading="eager"
      />
      <div class="space-y-4">
        <h1 class="text-3xl md:text-4xl font-bold">
          Developer. Advocate. Builder.
        </h1>
        <p class="text-lg leading-relaxed text-muted-foreground">
          <strong class="text-foreground"><em>Hi!</em> I'm Nick Taylor</strong> (<a
            href="/socials">@nickytonline</a
          >) — I'm a Developer Advocate at
          <a href="https://pomerium.com">Pomerium</a>, where I help developers
          understand the security layer for AI agents. GitHub Star, Agentic AI
          Foundation (AAIF) Ambassador, AWS Community Builder, and Microsoft
          MVP, I write, stream, and speak about Zero Trust security, agentic AI,
          MCP (Model Context Protocol), and open source.
        </p>
      </div>
    </section>

    {/* ── Featured: evergreen, curated best work ── */}
    {
      featuredTalks.length > 0 ||
      featuredGuides.length > 0 ||
      featuredPosts.length > 0 ? (
        <section class="space-y-10">
          <SectionHeader title="Featured" headingLevel={2} />

          {featuredTalks.length > 0 && (
            <div>
              <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
                Talks
              </h3>
              <div class="grid gap-6 xl:gap-8">
                {featuredTalks.map((talk) => (
                  <TalkCard
                    title={talk.data.title}
                    venueName={talk.data.venue.name}
                    venueUrl={talk.data.venue.url}
                    date={dateFilter(talk.data.date)}
                    href={`/talks/${talk.id}`}
                    video={talk.data.video}
                    coverImage={talk.data.cover_image}
                  />
                ))}
              </div>
            </div>
          )}

          {featuredGuides.length > 0 && (
            <div>
              <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
                Hands-On Tutorials
              </h3>
              <div class="grid gap-6 xl:gap-8">
                {featuredGuides.map((guide) => (
                  <GuideCard
                    title={guide.data.title}
                    description={guide.data.description}
                    date={dateFilter(guide.data.date)}
                    coverImage={guide.data.cover_image}
                    href={guide.data.url}
                    source={guide.data.source}
                  />
                ))}
              </div>
            </div>
          )}

          {featuredPosts.length > 0 && (
            <div>
              <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
                Writing
              </h3>
              <div class="grid gap-6 xl:gap-8">
                {featuredPosts.map((post) => (
                  <BlogPostCard
                    title={post.data.title}
                    date={dateFilter(post.data.date)}
                    image={post.data.cover_image}
                    href={`/blog/${post.id}`}
                  />
                ))}
              </div>
            </div>
          )}
        </section>
      ) : null
    }

    {/* ── Latest: recency feed ── */}
    <section class="space-y-10">
      <SectionHeader title="Latest" headingLevel={2} />

      {
        recentTalks.length > 0 && (
          <div>
            <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
              Talks
            </h3>
            <div class="grid gap-6 xl:gap-8">
              {recentTalks.map((talk) => (
                <TalkCard
                  title={talk.data.title}
                  venueName={talk.data.venue.name}
                  venueUrl={talk.data.venue.url}
                  date={dateFilter(talk.data.date)}
                  href={`/talks/${talk.id}`}
                  video={talk.data.video}
                  coverImage={talk.data.cover_image}
                  upcoming={talk.data.upcoming}
                />
              ))}
              <a
                href="/talks"
                class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-brand"
              >
                More talks<span class="text-2xl">→</span>
              </a>
            </div>
          </div>
        )
      }

      {
        errorMessage ? (
          <div>
            <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
              Live Streams
            </h3>
            <p class="text-destructive">{errorMessage}</p>
          </div>
        ) : null
      }
      {
        !errorMessage &&
        (latestUpcomingStreams.length > 0 || latestPastStreams.length > 0) ? (
          <div>
            <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
              Live Streams
            </h3>
            <div class="grid gap-6 xl:gap-8">
              {latestUpcomingStreams.length > 0 && (
                <StreamSchedule
                  schedule={latestUpcomingStreams}
                  locale={locale}
                  timezone={timezone}
                />
              )}
              {latestPastStreams.map((guest) => (
                <PastGuestCard
                  guest={guest}
                  locale={locale}
                  timezone={timezone}
                />
              ))}
            </div>
            <a
              href="/videos"
              class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-brand"
            >
              More live streams<span class="text-2xl">→</span>
            </a>
          </div>
        ) : null
      }

      {
        recentPosts.length > 0 && (
          <div>
            <h3 class="text-2xl font-bold tracking-tight text-balance mb-2">
              Blog Posts
            </h3>
            <div class="grid gap-6 xl:gap-8">
              {recentPosts.map((post) => (
                <BlogPostCard
                  title={post.data.title}
                  date={dateFilter(post.data.date)}
                  image={post.data.cover_image}
                  href={`/blog/${post.id}`}
                />
              ))}
              <a
                href="/blog"
                class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-brand"
              >
                More blog posts<span class="text-2xl">→</span>
              </a>
            </div>
          </div>
        )
      }
    </section>
  </div>
</Layout>
