---
import StreamSchedule from "../components/StreamSchedule.astro";
import PastGuestCard from "../components/PastGuestCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import Layout from "../layouts/MainLayout.astro";
import type { StreamGuestInfo } from "../utils/schedule-utils";
import { getLiveCollection } from "astro:content";
import { getCollection } from "astro:content";
import { site } from "../data/site";
import { dateFilter } from "../utils/filters";
import { fetchPastGuestsWithYouTube } from "../content/_loaders/stream-schedule";

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

// Sort by date descending
const sortedPosts = allPosts.sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

const recentPosts = sortedPosts.slice(0, site.maxPostsPerPage);

const locale =
  Astro.request.headers.get("Accept-Language")?.split(",")[0] ||
  Astro.request.headers.get("Accept-Language") ||
  "en-US";

let errorMessage = "";
let schedule: StreamGuestInfo[] = [];
let pastGuests: StreamGuestInfo[] = [];

const scheduleResult = await getLiveCollection("streamSchedule");

if (scheduleResult.error) {
  console.error("Error fetching stream schedule:", scheduleResult.error);
  errorMessage = "Error fetching stream schedule.";
} else {
  schedule = scheduleResult.entries?.map((entry) => entry.data) ?? [];

  // Only fetch past guests if there are no upcoming streams
  if (schedule.length === 0) {
    pastGuests = await fetchPastGuestsWithYouTube();
  }
}

const { timezone = "" } = Astro.locals.netlify.context.geo;

if (!errorMessage) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=0, must-revalidate"
  );
  Astro.response.headers.set(
    "Netlify-CDN-Cache-Control",
    "public, max-age=259200, must-revalidate"
  );
  Astro.response.headers.set("timezone", timezone);
  Astro.response.headers.set("Netlify-Vary", "header=Accept-Language|timezone");
}

export const prerender = false;
---

<Layout title="Welcome to Nick Taylor's website">
  <div class="space-y-12">
    <section class="flex flex-col md:flex-row gap-8 items-start">
      <img
        class="w-32 h-32 md:w-48 md:h-48 rounded-xl object-cover shrink-0"
        src="/assets/images/colour-headshot-500x500.jpg"
        alt="Headshot of Nick Taylor"
        loading="eager"
      />
      <div class="flex-1 space-y-4">
        <h1 class="text-3xl md:text-4xl font-bold">
          Just some dev from <span class="text-pink-600 dark:text-pink-400">Montreal</span>
        </h1>
        <p class="text-lg leading-relaxed text-muted-foreground">
          I'm <strong class="text-foreground">Nick Taylor</strong> (@nickytonline) — a developer advocate at
          <a href="https://pomerium.com" class="text-pink-600 dark:text-pink-400 font-semibold hover:underline">Pomerium</a>,
          Microsoft MVP, and GitHub Star. I write, stream, and speak about
          developer tools, open source, AI workflows, and Zero Trust security.
        </p>
        <p class="text-lg leading-relaxed text-muted-foreground">
          I also run <a href="https://onetipaweek.com" class="text-pink-600 dark:text-pink-400 font-semibold hover:underline">One Tip a Week</a> — a short newsletter with practical dev tips you can actually use.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a
            href="/blog"
            class="inline-flex items-center px-5 py-2.5 rounded-lg bg-pink-600 text-white font-semibold text-base hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-pink-600 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-colors"
          >
            Read the blog
          </a>
          <a
            href="https://onetipaweek.com"
            class="inline-flex items-center px-5 py-2.5 rounded-lg border-2 border-pink-600 text-pink-600 dark:text-pink-400 dark:border-pink-400 font-semibold text-base hover:bg-pink-600 hover:text-white dark:hover:bg-pink-400 dark:hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-600 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-colors"
          >
            Subscribe to the newsletter
          </a>
          <a
            href="/socials"
            class="inline-flex items-center px-5 py-2.5 rounded-lg border-2 border-foreground/20 text-foreground font-semibold text-base hover:border-pink-600 hover:text-pink-600 dark:hover:border-pink-400 dark:hover:text-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-600 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-colors"
          >
            Get in touch
          </a>
        </div>
      </div>
    </section>

    <SectionHeader title="Featured Content" headingLevel={2} />
    <section class="grid gap-6 xl:gap-8">
      {
        recentPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={dateFilter(post.data.date)}
            image={post.data.cover_image}
            href={`/blog/${post.id}`}
          />
        ))
      }
      <a
        href="/blog"
        class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-black dark:text-white hover:text-pink-600"
      >
        More blog posts<span class="text-2xl">→</span>
      </a>
    </section>

    <section class="grid gap-6 xl:gap-8">
      {
        errorMessage ? (
          <>
            <h2>Upcoming Live Streams</h2>
            <p class="text-red-600">{errorMessage}</p>
          </>
        ) : null
      }
      {
        !errorMessage && schedule.length > 0 ? (
          <>
            <h2>Upcoming Live Streams</h2>
            <StreamSchedule
              schedule={schedule}
              locale={locale}
              timezone={timezone}
            />
          </>
        ) : null
      }
      {
        !errorMessage && schedule.length === 0 && pastGuests.length > 0 ? (
          <>
            <h2>Recent Live Streams</h2>
            <div class="grid gap-6 xl:gap-8">
              {pastGuests.map((guest) => (
                <PastGuestCard
                  guest={guest}
                  locale={locale}
                  timezone={timezone}
                />
              ))}
            </div>
          </>
        ) : null
      }
    </section>
  </div>
</Layout>
