---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { getLiveCollection } from "astro:content";

const brewfileResult = await getLiveCollection("brewfile");
const brewfile = brewfileResult.entries ?? [];

const editorIds = ["visual-studio-code", "cursor"];
const editorCasks = brewfile.filter(
  (entry) => entry.data.type === "cask" && editorIds.includes(entry.data.name)
);

const desktopAppEntries = brewfile.filter(
  (entry) =>
    (entry.data.type === "cask" || entry.data.type === "mas") &&
    !editorIds.includes(entry.data.name) &&
    !entry.data.name.startsWith("font-")
);

const cliEntries = brewfile.filter((entry) => entry.data.type === "brew");

const getLink = (entry: (typeof brewfile)[number]) => {
  if (entry.data.homepage) return entry.data.homepage;

  if (entry.data.type === "cask") {
    return `https://formulae.brew.sh/cask/${entry.data.name}`;
  }
  if (entry.data.type === "brew") {
    return `https://formulae.brew.sh/formula/${entry.data.name}`;
  }
  if (entry.data.type === "mas") {
    return `https://apps.apple.com/app/id${entry.data.masId}`;
  }
  return "#";
};
