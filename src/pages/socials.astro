---
import MainLayout from "../layouts/MainLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import SectionHeader from "@/components/SectionHeader.astro";
---

<MainLayout
  title="Social Media - Nick Taylor"
  metaDesc="Connect with Nick Taylor on social media - GitHub, YouTube, Twitch, LinkedIn, Bluesky, and more."
  socialImage="/assets/images/page-og/socials.jpg"
>
  <article class="space-y-12">
    <header class="space-y-8">
      <SectionHeader title="Socials" headingLevel={1} />
      <p class="text-xl leading-relaxed text-muted-foreground">
        Find me across the web! I'm most active on <strong
          class="text-brand">GitHub</strong
        >,
        <strong class="text-brand">X</strong>, <strong
          class="text-brand">LinkedIn</strong
        >, and <strong class="text-brand">Dev.to</strong> where
        I share tech content, open source contributions, and connect with the developer
        community.
      </p>
    </header>

    <SocialLinks />
  </article>
</MainLayout>
