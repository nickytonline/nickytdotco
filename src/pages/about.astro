---
import SectionHeader from "@/components/SectionHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { Button } from "../components/Button";
---

<MainLayout
  title="About"
  metaDesc="Nick Taylor, software engineer and developer advocate with 20+ years in the industry and a decade of open source. I write, stream, speak, and build things. Currently in developer relations at Pomerium."
  socialImage="/assets/images/page-og/about.jpg"
  pageType="Page"
>
  <article class="space-y-12">
    <header>
      <SectionHeader title="About" headingLevel={1} />

      <div class="flex flex-col md:block overflow-hidden">
        <img
          class="w-48 h-48 md:w-64 md:h-64 rounded-xl object-cover self-center mb-6 md:mb-0 md:float-left md:mr-8"
          src="/assets/images/colour-headshot-500x500.jpg"
          alt="Headshot of Nick Taylor"
          loading="lazy"
        />

        <div class="space-y-6">
          <p class="text-xl leading-relaxed">
            I'm <strong>Nick Taylor</strong> (<a href="/socials">@nickytonline</a>)
            , a software engineer and developer advocate based in
            <strong>Montréal, Quebec, Canada</strong>. I've been building
            software for over twenty years, contributing to open source for
            about half that, and writing, streaming, and speaking about
            the things I'm learning along the way.
          </p>

          <p class="text-lg leading-relaxed text-muted-foreground">
            I've worked at <a
              href="https://opensauced.pizza"
              class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
              >OpenSauced</a
            >, <a
              href="https://dev.to"
              class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
              >dev.to</a
            >, and <a
              href="https://www.netlify.com/"
              class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
              >Netlify</a
            >, and I'm currently in developer relations at <a
              href="https://pomerium.com"
              class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
              >Pomerium</a
            >, where the focus is Zero Trust security, MCP (Model Context
            Protocol), and agentic AI. I'm also a <strong>GitHub Star</strong>,
            <a
              href="https://aaif.io/ambassadors/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand font-semibold hover:underline focus:underline focus:outline-none"><strong>AAIF Ambassador</strong></a>,
            <strong>AWS Community Builder</strong>, and
            <strong>Microsoft MVP</strong>.
          </p>

        </div>
      </div>
    </header>

    <section class="space-y-6">
      <SectionHeader title="Speaking & Conferences" headingLevel={2} />
      <p class="text-lg leading-relaxed text-muted-foreground">
        I speak at conferences like <strong>All Things Open</strong>, <strong>ConFoo</strong>, <strong>BlackHat USA</strong>,
        <strong>AI Engineer Europe</strong>, <strong>SREday</strong>, and <strong>MCP Dev Summit</strong>. I usually talk about web dev, open source,
        AI agents, or Zero Trust security.
      </p>
      <p class="text-lg leading-relaxed text-muted-foreground">
        You can browse <a
          href="/talks"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >all my talks and presentations</a
        > or visit the <a
          href="/speaking"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >speaking page</a
        > for topics, a bio, and how to book me.
      </p>
      <div class="pt-2">
        <Button href="mailto:nick@nickyt.co?subject=Speaking%20Inquiry">
          Book me to speak
          <span class="text-xl">→</span>
        </Button>
      </div>
    </section>

    <section class="space-y-6">
      <SectionHeader title="Content Creation" headingLevel={2} />
      <p class="text-lg leading-relaxed text-muted-foreground">
        I <a
          href="https://twitch.tv/nickytonline"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >stream on Twitch</a>
        and
        <a
          href="https://youtube.com/@nickytonline"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >YouTube</a>,
        write about whatever I'm figuring out, and send out
        <a
          href="https://onetipaweek.com"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >One Tip a Week</a>
        — a short newsletter with practical dev tips.
      </p>
    </section>

    <section class="space-y-6">
      <SectionHeader title="Open Source & Community" headingLevel={2} />
      <p class="text-lg leading-relaxed text-muted-foreground">
        I've been contributing to open source for about a decade, maintaining projects, reviewing PRs, and occasionally starting something new. You can browse <a
          href="/projects"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >my projects</a
        > or see the full list on <a
          href="https://github.com/nickytonline"
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >GitHub</a
        >.
      </p>
      <p class="text-lg leading-relaxed text-muted-foreground">
        I also mentor developers in the <a
          href="https://discord.gg/Q8XuFauC9"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >Let's Get Technical</a
        > community, a Discord for folks learning and levelling up in tech.
      </p>
    </section>

    <section class="space-y-6">
      <SectionHeader title="Connect" headingLevel={2} />
      <p class="text-lg leading-relaxed text-muted-foreground">
        Wanna get in touch? Drop me an e-mail at <a
          href="mailto:nick@nickyt.co"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >nick@nickyt.co</a
        >. You can also find me <a
          href="/socials"
          class="text-brand font-semibold hover:underline focus:underline focus:outline-none"
          >across the web</a
        >.
      </p>
    </section>
  </article>

  <p class="text-center text-muted-foreground mt-4">
    Open graph image by
    <a
      href="https://unsplash.com/@iamfelicia?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText"
    >
      Felicia Buitenwerf
    </a>
    on
    <a
      href="https://unsplash.com/photos/this-is-who-i-am-5yn5rGI5IUw?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText"
    >
      Unsplash
    </a>
  </p>
</MainLayout>
