---
import type { StreamGuestInfo } from "../utils/schedule-utils";
import { getLocalizedDate } from "../utils/schedule-utils";
import { getYouTubeId } from "../utils/youtube-utils";
import { slugifyVideo } from "../utils/video-utils";

interface Props {
  guest: StreamGuestInfo;
  locale: string;
  timezone: string;
}

const { guest, locale, timezone } = Astro.props;

const { date, title, guestName, guestTitle, youtubeStreamLink } = guest;

const guestDate = getLocalizedDate({
  date,
  locale,
  timezone,
  showTime: false,
});

const videoId = youtubeStreamLink ? getYouTubeId(youtubeStreamLink) : null;
const image = videoId
  ? `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`
  : undefined;
const videoPageUrl = youtubeStreamLink
  ? `/videos/${slugifyVideo(title, guestName)}`
  : undefined;

const guestInfo = `Guest: ${guestName}${guestTitle ? `, ${guestTitle}` : ""}`;
---

<div
  class="past-guest-card group grid md:flex gap-6 xl:gap-8"
  data-pagefind-ignore
>
  {
    image && videoPageUrl && (
      <a
        href={videoPageUrl}
        class="relative shrink-0 hidden md:block w-40 h-22.5 rounded-lg overflow-hidden hover:opacity-90 transition-opacity"
      >
        <img
          src={image}
          alt={`Watch ${title}`}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }
  <div class="flex-1 flex flex-col justify-center gap-2 min-w-0">
    <h3
      class="text-xl font-semibold leading-snug text-balance text-card-foreground"
    >
      {
        videoPageUrl ? (
          <a
            href={videoPageUrl}
            class="hover:text-pink-600 dark:hover:text-pink-400 transition-colors"
          >
            {title}
          </a>
        ) : (
          title
        )
      }
    </h3>
    <p class="text-base text-muted-foreground">{guestInfo}</p>
    <time class="italic text-base text-muted-foreground font-normal"
      >{guestDate}</time
    >
    {
      youtubeStreamLink && (
        <div class="flex items-center gap-3 mt-1">
          <a
            href={youtubeStreamLink}
            class="text-base text-foreground underline font-medium hover:text-pink-600 focus:text-pink-600 dark:hover:text-pink-400 dark:focus:text-pink-400 outline-none"
            target="_blank"
            rel="noopener noreferrer"
          >
            Watch on YouTube
          </a>
        </div>
      )
    }
  </div>
</div>
