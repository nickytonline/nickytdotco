---
interface Props {
  title: string;
  description: string;
  date: string;
  coverImage?: string;
  href: string;
  source: string;
}

const { title, description, date, coverImage, href, source } = Astro.props;
---

<article data-pagefind-ignore>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="group grid md:flex gap-6 xl:gap-8 no-underline outline-none transition-colors"
  >
    {
      coverImage ? (
        <div class="relative shrink-0 hidden md:block w-40 h-22.5 rounded-lg overflow-hidden bg-muted">
          <img
            src={coverImage}
            alt=""
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      ) : (
        <div class="relative shrink-0 hidden md:flex w-40 h-22.5 rounded-lg overflow-hidden bg-muted items-center justify-center">
          <svg
            class="w-8 h-8 text-muted-foreground/50"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
            />
          </svg>
        </div>
      )
    }
    <div class="flex-1 flex flex-col justify-center gap-2 min-w-0">
      <h3
        class="text-xl font-semibold leading-snug text-balance text-card-foreground group-hover:text-brand group-hover:underline group-focus:text-brand group-focus:underline dark:group-hover:text-brand dark:group-focus:text-brand"
      >
        {title}
      </h3>
      <p class="text-base text-muted-foreground leading-relaxed line-clamp-2">
        {description}
      </p>
      <div
        class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 text-muted-foreground"
      >
        <span class="text-base font-semibold text-brand">
          {source}
        </span>
        <span
          class="hidden sm:inline text-brand font-semibold"
        >
          •
        </span>
        <time class="italic text-base text-muted-foreground">{date}</time>
      </div>
    </div>
  </a>
</article>
