---
import { getYouTubeId } from "../utils/youtube-utils";

interface Props {
  title: string;
  venueName: string;
  venueUrl?: string;
  date: string;
  href: string;
  video?: {
    type: string;
    url: string;
    image?: { url: string };
  } | null;
}

const { title, venueName, venueUrl, date, href, video } = Astro.props;

let thumbnailUrl: string | undefined;
if (video?.type === "custom" && video.image) {
  thumbnailUrl = video.image.url;
} else if (video?.type === "youtube") {
  const videoId = getYouTubeId(video.url);
  if (videoId) {
    thumbnailUrl = `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;
  }
}
---

<article data-pagefind-ignore>
  <a
    href={href}
    class="group grid md:flex gap-6 xl:gap-8 no-underline outline-none transition-colors"
  >
    {
      thumbnailUrl ? (
        <div class="relative shrink-0 w-full md:w-40 h-45 md:h-30 rounded-lg overflow-hidden bg-muted">
          <img
            src={thumbnailUrl}
            alt=""
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      ) : (
        <div class="relative shrink-0 w-full md:w-40 h-45 md:h-30 rounded-lg overflow-hidden bg-muted flex items-center justify-center">
          <svg
            class="w-8 h-8 text-muted-foreground/50"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"
            />
          </svg>
        </div>
      )
    }
    <div class="flex-1 flex flex-col justify-center gap-2 min-w-0">
      <h3
        class="text-xl font-semibold leading-snug text-card-foreground group-hover:text-pink-600 group-hover:underline group-focus:text-pink-600 group-focus:underline dark:group-hover:text-pink-400 dark:group-focus:text-pink-400"
      >
        {title}
      </h3>
      <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 text-muted-foreground">
        {
          venueUrl ? (
            <span class="text-base font-semibold text-pink-600 dark:text-pink-400">
              {venueName}
            </span>
          ) : (
            <span class="text-base font-semibold text-pink-600 dark:text-pink-400">
              {venueName}
            </span>
          )
        }
        <span class="hidden sm:inline text-pink-600 dark:text-pink-400 font-semibold">
          •
        </span>
        <time class="italic text-base text-muted-foreground">{date}</time>
      </div>
    </div>
  </a>
</article>
