---
import type { CollectionEntry } from "astro:content";
import { dateFilter } from "../utils/filters";

interface Props {
  talks?: CollectionEntry<"talks">[];
  posts?: CollectionEntry<"blog">[];
}

const { talks, posts } = Astro.props;
const hasContent = (talks && talks.length > 0) || (posts && posts.length > 0);
---

{
  hasContent && (
    <aside class="pt-8 border-t border-muted" data-pagefind-ignore>
      {talks && talks.length > 0 && (
        <div class="mb-8">
          <h2 class="text-2xl font-bold mb-4 text-foreground">Related Talks</h2>
          <div class="space-y-4">
            {talks.map((talk) => (
              <a
                href={`/talks/${talk.id}`}
                class="group block no-underline outline-none transition-colors"
              >
                <h3 class="text-lg font-semibold text-foreground group-hover:text-pink-600 group-hover:underline group-focus:text-pink-600 group-focus:underline dark:group-hover:text-pink-400 dark:group-focus:text-pink-400">
                  {talk.data.title}
                </h3>
                <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground mt-1">
                  <span class="font-medium text-pink-600 dark:text-pink-400">
                    {talk.data.venue.name}
                  </span>
                  <span>•</span>
                  <time datetime={talk.data.date.toISOString()}>
                    {dateFilter(talk.data.date)}
                  </time>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {posts && posts.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold mb-4 text-foreground">Related Posts</h2>
          <div class="space-y-4">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="group block no-underline outline-none transition-colors"
              >
                <h3 class="text-lg font-semibold text-foreground group-hover:text-pink-600 group-hover:underline group-focus:text-pink-600 group-focus:underline dark:group-hover:text-pink-400 dark:group-focus:text-pink-400">
                  {post.data.title}
                </h3>
                <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground mt-1">
                  <time datetime={post.data.date.toISOString()}>
                    {dateFilter(post.data.date)}
                  </time>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </aside>
  )
}
